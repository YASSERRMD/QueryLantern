@page "/chat"
@using QueryLantern.Data
@using QueryLantern.Models
@using QueryLantern.Adapters
@using QueryLantern.Settings
@using QueryLantern.Services
@inject ChatService ChatSvc
@inject PlanService PlanSvc
@inject ConnectionRepository ConnectionRepo
@inject ProviderRepository ProviderRepo
@inject SettingsService Settings
@inject ModelRouter Router
@inject DecompositionService DecompSvc
@inject QueryLantern.Schema.SchemaCache SchemaCache

<PageTitle>Chat</PageTitle>

<h2>Chat</h2>
<p class="text-muted">Ask your data questions in natural language.</p>

<div class="row g-3 mb-3">
    <div class="col-md-5">
        <label class="form-label">Connection</label>
        <select class="form-select" @bind="_connectionId">
            <option value="0">-- select --</option>
            @foreach (var c in _connections)
            {
                <option value="@c.Id">@c.Name</option>
            }
        </select>
    </div>
    <div class="col-md-5">
        <label class="form-label">Provider</label>
        <select class="form-select" @bind="_providerId">
            <option value="0">-- select --</option>
            @foreach (var p in _providers)
            {
                <option value="@p.Id">@p.Name (@p.ModelId)</option>
            }
        </select>
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button class="btn btn-outline-secondary w-100" @onclick="Clear">New chat</button>
    </div>
</div>

<div class="chat-log card p-3 mb-3" style="min-height: 320px; max-height: 60vh; overflow:auto;">
    @if (ChatSvc.Entries.Count == 0)
    {
        <p class="text-muted mb-0">Pick a connection and provider, then ask a question.</p>
    }
    else
    {
        @foreach (var e in ChatSvc.Entries)
        {
            <div class="chat-entry @(e.Role)">
                <div class="chat-role">@e.Role</div>
                <div class="chat-content">@e.Content</div>
                @if (e.ToolCalls.Count > 0)
                {
                    <div class="chat-tools">
                        @foreach (var t in e.ToolCalls)
                        {
                            <span class="badge tool-call">@t</span>
                        }
                    </div>
                }
            </div>
        }
    }
</div>

@if (PlanSvc.Current is not null)
{
    <PlanView />
    @if (PlanSvc.State == PlanService.PlanRunState.AwaitingApproval)
    {
        <div class="d-flex gap-2 mb-3">
            <button class="btn btn-success" @onclick="RunPlan" disabled="@(_busy || _connectionId == 0 || _providerId == 0)">Run plan</button>
            <button class="btn btn-outline-secondary" @onclick="DiscardPlan">Discard plan</button>
        </div>
    }
}

@if (DecompSvc.Current is not null)
{
    <DecompositionView />
}

@if (ChatSvc.LastResultSetJson is not null)
{
    <ResultGrid Json="ChatSvc.LastResultSetJson" />
}

@if (ChatSvc.LastGrounding is not null && !string.IsNullOrEmpty(ChatSvc.LastAnswer))
{
    <GroundingView Answer="ChatSvc.LastAnswer" Result="ChatSvc.LastGrounding" />
}

@if (ChatSvc.LastCritique is not null)
{
    <CritiqueView Critique="ChatSvc.LastCritique" />
}

@if (ChatSvc.State == ChatService.ChatState.AwaitingApproval && ChatSvc.Pending is not null)
{
    <div class="approval card p-3 mb-3 border-warning">
        <h5 class="text-warning">⚠ Approve this write before it runs</h5>
        <p class="text-muted mb-2">This statement will modify the database. Review it carefully — approving executes it exactly once.</p>
        <pre class="sql-preview">@ChatSvc.Pending.Sql</pre>
        <div class="d-flex gap-2">
            <button class="btn btn-primary" @onclick="Approve">Approve &amp; run</button>
            <button class="btn btn-outline-danger" @onclick="Reject">Reject</button>
        </div>
    </div>
}

@if (ChatSvc.State == ChatService.ChatState.Error)
{
    <div class="alert alert-danger">@ChatSvc.LastError</div>
}

<div class="input-row d-flex gap-2">
    <input class="form-control" placeholder="Ask something like 'how many users signed up last week?'"
           @bind="_draft" @onkeydown="OnKey" disabled="@(_busy || _connectionId == 0 || _providerId == 0)" />
    <button class="btn btn-outline-primary" @onclick="Plan" disabled="@(_busy || _connectionId == 0 || _providerId == 0)">Plan</button>
    <button class="btn btn-outline-info" @onclick="Decompose" disabled="@(_busy || _connectionId == 0)">Decompose</button>
    <button class="btn btn-primary" @onclick="Send" disabled="@(_busy || _connectionId == 0 || _providerId == 0)">Send</button>
</div>

@if (ChatSvc.LastCost is not null)
{
    <div class="text-muted mt-2">Estimated cost: @ChatSvc.LastCost</div>
}

<div class="saved-row d-flex gap-2 mt-3 align-items-center">
    <input class="form-control" style="max-width:280px" placeholder="Name this analysis" @bind="_saveName" />
    <button class="btn btn-outline-secondary" @onclick="Save" disabled="@(_busy || ChatSvc.Entries.Count == 0)">Save analysis</button>
    @if (ChatSvc.LastResultSetJson is not null)
    {
        var csv = QueryLantern.Tools.CsvExporter.ToCsv(ChatSvc.LastResultSetJson);
        <a class="btn btn-outline-secondary" href="@("data:text/csv;base64," + Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(csv)))" download="result.csv">Export CSV</a>
    }
</div>
}

@code {
    private List<ConnectionProfile> _connections = new();
    private List<ProviderProfile> _providers = new();
    private int _connectionId;
    private int _providerId;
    private string _draft = string.Empty;
    private string _saveName = string.Empty;
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        _connections = (await ConnectionRepo.ListAsync()).ToList();
        _providers = (await ProviderRepo.ListAsync()).ToList();
        ChatSvc.Changed += OnChanged;
        PlanSvc.Changed += OnChanged;
        DecompSvc.Changed += OnChanged;
    }

    public void Dispose()
    {
        ChatSvc.Changed -= OnChanged;
        PlanSvc.Changed -= OnChanged;
        DecompSvc.Changed -= OnChanged;
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);

    private async Task Plan()
    {
        if (string.IsNullOrWhiteSpace(_draft) || _connectionId == 0) return;
        _busy = true;
        StateHasChanged();
        await PlanSvc.PlanAsync(_draft, _connectionId);
        _busy = false;
        StateHasChanged();
    }

    private async Task RunPlan()
    {
        if (_connectionId == 0 || _providerId == 0) return;
        _busy = true;
        StateHasChanged();
        try
        {
            PlanSvc.ApprovePlan();
            var resolved = await Settings.ResolveConnectionAsync(_connectionId);
            var adapter = AdapterFactory.Create(resolved.Profile.Engine);
            await adapter.OpenAsync(resolved.Profile, resolved.Password);
            var (providerConfig, model) = await Router.ResolveAsync(_providerId);
            await PlanSvc.RunAsync(providerConfig, model, adapter, 1000);
            adapter.Dispose();
        }
        catch (Exception ex)
        {
            PlanSvc.SetRunError(ex.Message);
        }
        _busy = false;
        StateHasChanged();
    }

    private void DiscardPlan()
    {
        PlanSvc.Clear();
        StateHasChanged();
    }

    private async Task Decompose()
    {
        if (string.IsNullOrWhiteSpace(_draft)) return;
        _busy = true;
        StateHasChanged();
        var summary = SchemaCache.Get(_connectionId) is { } model
            ? QueryLantern.Schema.SchemaSerializer.ToCompactText(model)
            : null;
        DecompSvc.DecomposeAndPlan(_draft, summary);
        _busy = false;
        StateHasChanged();
    }

    private async Task Send()
    {
        if (string.IsNullOrWhiteSpace(_draft)) return;
        var message = _draft;
        _draft = string.Empty;
        _busy = true;
        StateHasChanged();
        await ChatSvc.SendAsync(message, _connectionId, _providerId);
        _busy = false;
        StateHasChanged();
    }

    private async Task Approve()
    {
        _busy = true;
        StateHasChanged();
        await ChatSvc.ApproveAsync();
        _busy = false;
        StateHasChanged();
    }

    private async Task Reject()
    {
        _busy = true;
        StateHasChanged();
        await ChatSvc.RejectAsync();
        _busy = false;
        StateHasChanged();
    }

    private void Clear()
    {
        ChatSvc.Reset();
        _busy = false;
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_saveName)) _saveName = $"Analysis {DateTime.Now:yyyy-MM-dd HH:mm}";
        await ChatSvc.SaveAsync(_saveName);
        _saveName = string.Empty;
        StateHasChanged();
    }

    private void OnKey(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter") _ = Send();
    }
}
