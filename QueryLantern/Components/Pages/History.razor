@page "/history"
@using QueryLantern.Data
@using QueryLantern.Services
@using QueryLantern.Tools
@inject SavedAnalysisRepository Saved
@inject ChatService ChatSvc
@inject NavigationManager Nav

<PageTitle>History</PageTitle>

<h2>Saved Analyses</h2>
<p class="text-muted">Reopen a previous conversation, export it, or delete it.</p>

@if (_items.Count == 0)
{
    <p class="text-muted">No saved analyses yet. Use "Save analysis" in the chat to keep one.</p>
}
else
{
    <div class="row g-3">
        @foreach (var a in _items)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card p-3 h-100">
                    <h5>@a.Name</h5>
                    <div class="text-muted small mb-2">@a.CreatedAt.ToString("u")</div>
                    <div class="d-flex flex-column gap-2">
                        <button class="btn btn-outline-secondary" @onclick="() => Open(a)">Open in chat</button>
                        <button class="btn btn-outline-secondary" @onclick="() => ExportJson(a)">Export JSON</button>
                        <button class="btn btn-outline-danger" @onclick="() => Delete(a)">Delete</button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<SavedAnalysis> _items = new();

    protected override async Task OnInitializedAsync()
    {
        _items = (await Saved.ListAsync()).ToList();
    }

    private void Open(SavedAnalysis a)
    {
        ChatSvc.LoadFromPayload(a.Payload);
        Nav.NavigateTo("/chat");
    }

    private void ExportJson(SavedAnalysis a)
    {
        var bytes = System.Text.Encoding.UTF8.GetBytes(a.Payload);
        var url = "data:application/json;base64," + Convert.ToBase64String(bytes);
        Nav.NavigateTo(url, forceLoad: true);
    }

    private async Task Delete(SavedAnalysis a)
    {
        await Saved.DeleteAsync(a.Id);
        _items = (await Saved.ListAsync()).ToList();
    }
}
