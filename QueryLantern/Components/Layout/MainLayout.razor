@inherits LayoutComponentBase

<div class="page">
    <aside class="sidebar">
        <div class="brand">
            <span class="brand-mark">⌗</span>
            <span class="brand-name">QueryLantern</span>
        </div>
        <NavMenu />
    </aside>

    <main>
        <div class="top-row">
            <span class="app-tagline">Conversational SQL, on your data, on your machine</span>
        </div>
        <article class="content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
