{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Catalog": {
    "Path": "catalog.db"
  },
  "Approval": {
    "RequireApproval": true,
    "AutoRejectWrites": false
  },
  "LocalFirst": {
    "Enabled": true
  },
  "Ancora": {
    "BaseUrl": "http://localhost:11434/v1",
    "AuthEnvVar": "ANCORA_API_KEY",
    "ChatCompletionsPath": "/v1/chat/completions"
  }
}
